# Scientist planner, OpenAI-compatible endpoint
# Used by the production open lab for agenda/protocol/next-decision JSON.
LUCKYLOOP_AGENT_BASE_URL=http://localhost:8000/v1
LUCKYLOOP_AGENT_MODEL=deepseek-chat
LUCKYLOOP_AGENT_API_KEY=replace-me
# Optional for models that support/need it.
# LUCKYLOOP_AGENT_DISABLE_THINKING=1

# Language world model, OpenAI-compatible endpoint
# Used before compute to predict likely observations, risks and claim impact.
LUCKYWORLD_SIMULATOR_BASE_URL=http://localhost:8000/v1
LUCKYWORLD_SIMULATOR_MODEL=Qwen/Qwen-AgentWorld-35B-A3B
LUCKYWORLD_SIMULATOR_API_KEY=dummy
LUCKYWORLD_SIMULATOR_TIMEOUT_SECONDS=120

# Optional: local experiment timeout in seconds.
LUCKYLOOP_EXECUTION_TIMEOUT_SECONDS=240

# Optional: Notion progress sync.
NOTION_TOKEN=secret_xxx
NOTION_PAGE_URL=https://www.notion.so/your-workspace/your-page-id
# or NOTION_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
